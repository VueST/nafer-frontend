<UserControl
    x:Class="Nafer.WinUI.Features.Auth.SignUpControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:auth="using:Nafer.WinUI.Features.Auth"
    x:DataType="auth:SignUpControl"
    UseLayoutRounding="True">

    <Grid Padding="16,0,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Form Fields -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,8,0,8">
            <TextBox
                Header="Email"
                PlaceholderText="Enter your email"
                Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                InputScope="EmailSmtpAddress" />

            <PasswordBox
                Header="Password"
                PlaceholderText="min. 6 characters"
                Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <PasswordBox
                Header="Confirm Password"
                PlaceholderText="Re-type password"
                Password="{x:Bind ViewModel.ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!-- Error Message -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Severity="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            IsClosable="False"
            Margin="0,0,0,12" />

        <!-- Register Button -->
        <Grid Grid.Row="2">
            <Button
                Content="Create Account"
                Height="32"
                Command="{x:Bind ViewModel.RegisterCommand}"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}" />
            <ProgressRing
                Width="20" Height="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,16,0"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>
