<Page
    x:Class="Nafer.WinUI.Features.Shell.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:nav="using:Nafer.WinUI.Infrastructure.Navigation"
    xmlns:auth="using:Nafer.WinUI.Features.Auth"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    Loaded="OnLoaded">

    <Page.Resources>
        <Style x:Key="SimpleAccountButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Page.Resources>

    <NavigationView
        x:Name="NavigationViewControl"
        AlwaysShowHeader="False"
        IsBackButtonVisible="Collapsed"
        IsPaneToggleButtonVisible="False"
        IsSettingsVisible="False"
        IsPaneOpen="False"
        PaneDisplayMode="Left"
        OpenPaneLength="200"
        SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}">

        <NavigationView.MenuItems>
            <NavigationViewItem
                Content="Home"
                Icon="Home"
                nav:NavigationHelper.NavigateTo="Nafer.WinUI.Features.Home.HomeViewModel" />

            <!-- Moderation Dashboard — visible to Mod and Admin roles only -->
            <NavigationViewItem
                Content="Moderation"
                Visibility="{x:Bind ViewModel.Account.CanModerate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                nav:NavigationHelper.NavigateTo="Nafer.WinUI.Features.Moderation.ModerationViewModel">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8C3;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Admin Panel — visible to Admin role only -->
            <NavigationViewItem
                Content="Admin"
                Visibility="{x:Bind ViewModel.Account.IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                nav:NavigationHelper.NavigateTo="Nafer.WinUI.Features.Admin.AdminViewModel">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE7EF;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem
                Content="Settings"
                nav:NavigationHelper.NavigateTo="Nafer.WinUI.Features.Settings.SettingsPageViewModel">
                <NavigationViewItem.Icon>
                    <AnimatedIcon>
                        <AnimatedIcon.Source>
                            <animatedvisuals:AnimatedSettingsVisualSource />
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <SymbolIconSource Symbol="Setting" />
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <NavigationView.PaneFooter>
            <Button x:Name="AccountNavItem"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Height="48"
                    CornerRadius="4"
                    Tapped="AccountNavItem_Tapped"
                    ToolTipService.ToolTip="Account">
                <Grid>
                    <!-- Col 0: Exactly 40px wide with 4px left/right margin = 48px (Standard CompactPaneLength). Centers the Avatar perfectly. -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Avatar, always visible and perfectly centered vertically with other Navigation icons -->
                    <PersonPicture Width="34" Height="34" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Initials="{x:Bind ViewModel.Account.UserInitials, Mode=OneWay}" />
                    
                    <!-- Details, only visible when IsPaneOpen is true -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,12,0"
                                Visibility="{x:Bind NavigationViewControl.IsPaneOpen, Mode=OneWay}">
                        <TextBlock Text="{x:Bind ViewModel.Account.UserName, Mode=OneWay}" 
                                   FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind ViewModel.Account.UserEmail, Mode=OneWay}" 
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
                <FlyoutBase.AttachedFlyout>
                    <Flyout Placement="RightEdgeAlignedTop">
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                                <Setter Property="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                                <Setter Property="Margin" Value="0,-40,0,0" />
                            </Style>
                        </Flyout.FlyoutPresenterStyle>
                        <auth:AccountFlyoutControl ViewModel="{x:Bind ViewModel.Account, Mode=OneWay}" />
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
            </Button>
        </NavigationView.PaneFooter>

        <Grid>
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Frame x:Name="NavigationFrame" />
            </ScrollViewer>

            <!-- Update Notification Bar -->
            <InfoBar Title="Update Available"
                     Message="{x:Bind ViewModel.UpdateVersion, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay}"
                     Severity="Informational"
                     BorderThickness="0"
                     VerticalAlignment="Top"
                     Margin="16,12,16,0"
                     CornerRadius="8"
                     IsClosable="True">
                <InfoBar.ActionButton>
                    <Button Content="Update Now" 
                            Click="{x:Bind ViewModel.StartUpdateAsync}"
                            Style="{StaticResource AccentButtonStyle}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Background Download Indicator (Bottom Right) -->
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                        Margin="24" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <ProgressRing Value="{x:Bind ViewModel.UpdateProgress, Mode=OneWay}" 
                                  IsIndeterminate="False" Width="32" Height="32" />
                    <TextBlock Text="{x:Bind ViewModel.UpdateProgress, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:F0\}%'}" 
                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="9" />
                </Grid>
                <TextBlock Text="Downloading..." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </NavigationView>
</Page>
