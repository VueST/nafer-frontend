<Page
    x:Class="Nafer.WinUI.Features.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    NavigationCacheMode="Required">

    <Grid HorizontalAlignment="Stretch" x:Name="RootGrid">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowStates">
                <!-- Small/Normal screens -->
                <VisualState x:Name="NormalState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Margin" Value="120,24" />
                    </VisualState.Setters>
                </VisualState>
                <!-- Large screens (e.g., maximized on 1080p) -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Margin" Value="240,24" />
                    </VisualState.Setters>
                </VisualState>
                <!-- Ultra-wide screens -->
                <VisualState x:Name="UltraWideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1600" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Margin" Value="400,24" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <StackPanel Spacing="4">

                <!-- Page Header -->
                <TextBlock
                    Text="Settings"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,24" />

                <!-- User Preferences -->
                <TextBlock
                    Text="User Preferences"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Margin="0,0,0,8" />

                <ctk:SettingsCard
                    Header="Theme"
                    Description="Set color scheme of application"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox
                        MinWidth="150"
                        HorizontalAlignment="Right"
                        ItemsSource="{x:Bind ViewModel.Themes}"
                        SelectedItem="{x:Bind ViewModel.Theme, Mode=TwoWay}" />
                </ctk:SettingsCard>

                <!-- Startup -->
                <TextBlock
                    Text="Startup"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Margin="0,24,0,8" />

                <ctk:SettingsCard
                    Header="Start Minimized"
                    Description="Start application minimized to tray"
                    HeaderIcon="{ui:FontIcon Glyph=&#xEE47;}">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.StartMinimizedToTray, Mode=TwoWay}"
                        OnContent="On"
                        OffContent="Off" />
                </ctk:SettingsCard>

                <ctk:SettingsCard
                    Header="Close to Tray"
                    Description="When closing application, minimize to system tray"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE770;}">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.MinimizeToTrayOnClose, Mode=TwoWay}"
                        OnContent="On"
                        OffContent="Off" />
                </ctk:SettingsCard>

                <ctk:SettingsCard
                    Header="Auto Update"
                    Description="Automatically check for updates on startup"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE777;}">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.AutoUpdate, Mode=TwoWay}"
                        OnContent="On"
                        OffContent="Off" />
                </ctk:SettingsCard>

                <!-- About -->
                <TextBlock
                    Text="About"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Margin="0,24,0,8" />

                <ctk:SettingsExpander
                    Header="Nafer"
                    Description="A clean, fast, and beautiful content hub."
                    HeaderIcon="{ui:FontIcon Glyph=&#xE946;}">

                    <TextBlock
                        Text="{x:Bind ViewModel.AppVersion}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ctk:SettingsExpander.Items>
                        <ctk:SettingsCard Header="License" Description="MIT License" />
                        <ctk:SettingsCard Header="Built with" Description="WinUI 3, ReactiveUI, .NET 9" />
                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

            </StackPanel>
    </Grid>
</Page>
