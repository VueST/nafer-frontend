<winex:WindowEx
    x:Class="Nafer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="using:Nafer.WinUI.Features.Shell"
    xmlns:winex="using:WinUIEx"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    MinWidth="600"
    MinHeight="400"
    IsTitleBarVisible="False">

    <winex:WindowEx.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </winex:WindowEx.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Branded TitleBar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" SizeChanged="AppTitleBar_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BrandingColumn" Width="Auto" />
                <ColumnDefinition x:Name="DragColumn" Width="*" />
                <ColumnDefinition x:Name="CaptionColumn" Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0" Spacing="8">
                <!-- Navigation History Group -->
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- Back Button -->
                    <Button x:Name="CustomBackButton"
                            Click="BackButton_Click"
                            IsEnabled="{x:Bind Shell.ViewModel.IsBackEnabled, Mode=OneWay}"
                            Width="40" Height="36"
                            ToolTipService.ToolTip="Back"
                            Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    </Button>

                    <!-- Forward Button -->
                    <Button x:Name="CustomForwardButton"
                            Click="ForwardButton_Click"
                            IsEnabled="{x:Bind Shell.ViewModel.IsForwardEnabled, Mode=OneWay}"
                            Width="40" Height="36"
                            ToolTipService.ToolTip="Forward"
                            Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72A;" FontSize="14" />
                    </Button>
                </StackPanel>

                <!-- Sidebar Toggle -->
                <Button x:Name="CustomPaneButton"
                        Click="PaneButton_Click"
                        Width="40" Height="36"
                        ToolTipService.ToolTip="Toggle Sidebar"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <AnimatedIcon>
                        <AnimatedIcon.Source>
                            <animatedvisuals:AnimatedGlobalNavigationButtonVisualSource />
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <SymbolIconSource Symbol="GlobalNavigationButton" />
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>
                </Button>

                <!-- Application Branding -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Image Source="Assets/32x32.png" Width="18" Height="18" VerticalAlignment="Center" />
                    <TextBlock Text="Nafer" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                    <TextBlock x:Name="AppVersionText" VerticalAlignment="Center" FontSize="11" Opacity="0.6" Margin="4,0,0,0" />
                </StackPanel>
            </StackPanel>
            
            <!-- Pure Drag Region strictly mapped in CodeBehind -->
            <Grid x:Name="DragRegion" Grid.Column="1" Background="Transparent" />

            <!-- Custom Caption Buttons (Minimize, Maximize, Close) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                        Width="46" Height="40" Background="Transparent" BorderThickness="0" CornerRadius="0">
                    <FontIcon Glyph="&#xE921;" FontSize="10" />
                </Button>
                <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                        Width="46" Height="40" Background="Transparent" BorderThickness="0" CornerRadius="0">
                    <FontIcon x:Name="MaximizeIcon" Glyph="&#xE922;" FontSize="10" />
                </Button>
                <!-- Close Button with standard Windows Red hover style -->
                <Button x:Name="CloseButton" Click="CloseButton_Click"
                        Width="46" Height="40" Background="Transparent" BorderThickness="0" CornerRadius="0">
                    <Button.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E81123" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#8B0A14" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                        </ResourceDictionary>
                    </Button.Resources>
                    <FontIcon Glyph="&#xE8BB;" FontSize="10" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- App content -->
        <shell:ShellPage x:Name="Shell" Grid.Row="1" />
    </Grid>
</winex:WindowEx>
