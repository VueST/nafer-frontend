<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" 
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Nafer" 
           Manufacturer="VueST" 
           Version="$(var.BuildVersion)" 
           UpgradeCode="462272e2-9d3d-4c31-893f-c9664535eca2"
           Language="1033"
           Scope="perUser">
           
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Application Icon -->
    <Icon Id="AppIcon" SourceFile="..\Nafer.WinUI\Assets\WindowIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <Feature Id="Main">
      <ComponentGroupRef Id="AppComponents" />
      
      <!-- Desktop and Start Menu Shortcuts -->
      <Component Id="AppShortcut" Guid="724ea261-2632-4740-9844-462272e29d3d" Directory="DesktopFolder">
        <Shortcut Name="Nafer" 
                  Description="A clean and fast content hub." 
                  Target="[INSTALLFOLDER]Nafer.WinUI.exe" 
                  Icon="AppIcon"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\VueST\Nafer" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <Component Id="StartMenuShortcut" Guid="834ea261-2632-4740-9844-462272e29d3e" Directory="ApplicationProgramsFolder">
        <Shortcut Name="Nafer" 
                  Description="A clean and fast content hub." 
                  Target="[INSTALLFOLDER]Nafer.WinUI.exe" 
                  Icon="AppIcon"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupShortcut" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\VueST\Nafer" Name="startmenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </Feature>

    <!-- Custom Action: Launch app after install (simple EXE call) -->
    <CustomAction Id="LaunchApplication" 
                  Directory="INSTALLFOLDER" 
                  ExeCommand="[INSTALLFOLDER]Nafer.WinUI.exe" 
                  Execute="immediate" 
                  Impersonate="yes" 
                  Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- UI: Standard InstallDir flow -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Nafer" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Nafer" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

</Wix>
